{
  "name": "ccnow",
  "version": "0.0.1",
  "description": "Composable, spaceship-inspired status line for Claude Code",
  "type": "module",
  "main": "dist/cli.js",
  "bin": {
    "ccnow": "dist/cli.js"
  },
  "scripts": {
    "build": "tsc",
    "test": "NODE_OPTIONS='--experimental-vm-modules' jest",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{ts,json,yaml,yml,md}": [
      "prettier --check"
    ],
    "*.ts": [
      "eslint"
    ]
  },
  "files": [
    "dist"
  ],
  "keywords": [
    "claude",
    "claude-code",
    "statusline",
    "cli"
  ],
  "author": "Jason Heddings",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/jheddings/ccnow.git"
  },
  "homepage": "https://github.com/jheddings/ccnow",
  "engines": {
    "node": ">=18"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/jest": "^29.5.0",
    "@types/node": "^20.19.37",
    "@typescript-eslint/eslint-plugin": "^8.57.0",
    "@typescript-eslint/parser": "^8.57.0",
    "eslint": "^10.0.3",
    "git-cliff": "^2.12.0",
    "globals": "^17.4.0",
    "husky": "^9.1.7",
    "jest": "^29.7.0",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.1",
    "ts-jest": "^29.2.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.5.0"
  }
}
