{
  "segments": [
    {
      "segment": "git.repo",
      "style": { "color": "39" }
    },
    {
      "when": "git.repo == ''",
      "children": [
        {
          "segment": "pwd.name",
          "style": { "color": "39" }
        }
      ]
    },
    {
      "segment": "git.branch",
      "when": "git.branch != '' && git.branch != 'main'",
      "style": { "color": "whiteBright", "bold": true, "prefix": " | " }
    },
    {
      "segment": "git.modified",
      "when": "value > 0",
      "style": { "color": "yellow", "prefix": " ~" }
    },
    {
      "segment": "git.untracked",
      "when": "value > 0",
      "style": { "color": "cyan", "prefix": " ?" }
    },
    {
      "segment": "context.percent.used",
      "when": "context.percent.used >= 50",
      "style": { "color": "yellow", "prefix": " | " }
    }
  ]
}
