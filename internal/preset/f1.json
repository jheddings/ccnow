{
  "segments": [
    {
      "expr": "pwd.smart",
      "style": { "color": "white", "bgcolor": "#DC0000", "prefix": " \uf07b " }
    },
    {
      "expr": "pwd.name",
      "style": { "color": "white", "bgcolor": "#DC0000", "bold": true, "suffix": " " }
    },
    {
      "value": "\ue0b0",
      "style": { "color": "#DC0000", "bgcolor": "#3A3A3A" }
    },
    {
      "expr": "git.owner",
      "style": { "color": "#AAAAAA", "bgcolor": "#3A3A3A", "prefix": " \uf09b " }
    },
    {
      "expr": "git.repo",
      "style": { "color": "white", "bgcolor": "#3A3A3A", "bold": true, "prefix": "/" }
    },
    {
      "expr": "git.branch",
      "style": { "color": "white", "bgcolor": "#3A3A3A", "bold": true, "prefix": " \ue0a0 " }
    },
    {
      "expr": "git.insertions",
      "when": "value > 0",
      "style": { "color": "#50FA7B", "bgcolor": "#3A3A3A", "prefix": " +" }
    },
    {
      "expr": "git.deletions",
      "when": "value > 0",
      "style": { "color": "#FF6B6B", "bgcolor": "#3A3A3A", "prefix": " -" }
    },
    {
      "expr": "git.modified",
      "when": "value > 0",
      "style": { "color": "#FFD700", "bgcolor": "#3A3A3A", "prefix": " ~" }
    },
    {
      "expr": "git.untracked",
      "when": "value > 0",
      "style": { "color": "#8BE9FD", "bgcolor": "#3A3A3A", "prefix": " ?", "suffix": " " }
    },
    {
      "value": "\ue0b0",
      "style": { "color": "#3A3A3A" }
    },
    {
      "value": "\n"
    },
    {
      "expr": "model.name",
      "style": {
        "color": "white",
        "bgcolor": "#003DA5",
        "bold": true,
        "prefix": " ",
        "suffix": " "
      }
    },
    {
      "value": "\ue0b0",
      "style": { "color": "#003DA5", "bgcolor": "#2D2D2D" }
    },
    {
      "expr": "context.tokens",
      "style": { "color": "white", "bgcolor": "#2D2D2D", "bold": true, "prefix": " \uf0e4 " }
    },
    {
      "expr": "context.size",
      "style": { "color": "white", "bgcolor": "#2D2D2D", "prefix": "/" }
    },
    {
      "expr": "context.percent.used",
      "style": { "color": "white", "bgcolor": "#2D2D2D", "prefix": " (", "suffix": ")" }
    },
    {
      "expr": "speed.output",
      "style": { "color": "#50FA7B", "bgcolor": "#2D2D2D", "prefix": " \uf0e7 ", "suffix": " " }
    },
    {
      "value": "\ue0b0",
      "style": { "color": "#2D2D2D", "bgcolor": "#006633" }
    },
    {
      "expr": "cost.usd",
      "style": {
        "color": "white",
        "bgcolor": "#006633",
        "bold": true,
        "prefix": " ",
        "suffix": " "
      }
    },
    {
      "value": "\ue0b0",
      "style": { "color": "#006633", "bgcolor": "#FF8000" }
    },
    {
      "expr": "session.duration.total",
      "style": {
        "color": "black",
        "bgcolor": "#FF8000",
        "bold": true,
        "prefix": " \uf017 ",
        "suffix": " "
      }
    },
    {
      "value": "\ue0b0",
      "style": { "color": "#FF8000", "bgcolor": "#3A3A3A" }
    },
    {
      "expr": "session.lines-added",
      "when": "value > 0",
      "style": { "color": "#50FA7B", "bgcolor": "#3A3A3A", "prefix": " +" }
    },
    {
      "expr": "session.lines-removed",
      "when": "value > 0",
      "style": { "color": "#FF6B6B", "bgcolor": "#3A3A3A", "prefix": " -", "suffix": " " }
    },
    {
      "value": "\ue0b0",
      "style": { "color": "#3A3A3A" }
    },
    {
      "value": "\n"
    },
    {
      "expr": "system.load.avg1",
      "style": {
        "color": "white",
        "bgcolor": "#444444",
        "prefix": " \u26a1 "
      }
    },
    {
      "value": "\ue0b0",
      "style": { "color": "#444444", "bgcolor": "#333333" }
    },
    {
      "expr": "system.mem.used",
      "style": { "color": "#8BE9FD", "bgcolor": "#333333", "prefix": " \uf233 " }
    },
    {
      "expr": "system.mem.total",
      "style": { "color": "#AAAAAA", "bgcolor": "#333333", "prefix": "/" }
    },
    {
      "expr": "system.mem.percent",
      "style": { "color": "white", "bgcolor": "#333333", "prefix": " (", "suffix": ")" }
    },
    {
      "value": "\ue0b0",
      "style": { "color": "#333333", "bgcolor": "#2A2A2A" }
    },
    {
      "expr": "system.disk.used",
      "style": { "color": "#FFD700", "bgcolor": "#2A2A2A", "prefix": " \uf0a0 " }
    },
    {
      "expr": "system.disk.total",
      "style": { "color": "#AAAAAA", "bgcolor": "#2A2A2A", "prefix": "/" }
    },
    {
      "expr": "system.disk.percent",
      "style": { "color": "white", "bgcolor": "#2A2A2A", "prefix": " (", "suffix": ")" }
    },
    {
      "value": "\ue0b0",
      "style": { "color": "#2A2A2A", "bgcolor": "#222222" }
    },
    {
      "when": "system.battery.percent > 0",
      "children": [
        {
          "expr": "system.battery.percent",
          "style": { "color": "#50FA7B", "bgcolor": "#222222", "prefix": " \uf240 " }
        },
        {
          "expr": "system.battery.state",
          "style": { "color": "#AAAAAA", "bgcolor": "#222222", "prefix": " " }
        }
      ]
    },
    {
      "expr": "system.uptime",
      "style": { "color": "#AAAAAA", "bgcolor": "#222222", "prefix": " \uf017 ", "suffix": " " }
    },
    {
      "value": "\ue0b0",
      "style": { "color": "#222222" }
    }
  ]
}
