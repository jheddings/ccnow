{
  "segments": [
    {
      "segment": "pwd.smart",
      "style": {
        "color": "31"
      }
    },
    {
      "segment": "pwd.name",
      "style": {
        "color": "39",
        "bold": true
      }
    },
    {
      "segment": "group",
      "style": {
        "prefix": " | ",
        "color": "240"
      },
      "children": [
        {
          "segment": "git.branch",
          "style": {
            "color": "whiteBright",
            "bold": true,
            "prefix": " "
          }
        },
        {
          "segment": "git.insertions",
          "when": "value > 0",
          "style": {
            "color": "green",
            "prefix": " · +"
          }
        },
        {
          "segment": "git.deletions",
          "when": "value > 0",
          "style": {
            "color": "red",
            "prefix": " -"
          }
        }
      ]
    },
    {
      "segment": "group",
      "style": {
        "prefix": " | "
      },
      "children": [
        {
          "segment": "context.tokens",
          "style": {
            "color": "white",
            "bold": true
          }
        },
        {
          "segment": "context.percent.used",
          "style": {
            "color": "white",
            "prefix": " (",
            "suffix": ")"
          }
        }
      ]
    },
    {
      "segment": "session.duration.total",
      "style": {
        "color": "magenta",
        "prefix": " · "
      }
    }
  ]
}
