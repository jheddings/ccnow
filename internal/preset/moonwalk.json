{
  "segments": [
    {
      "expr": "pwd.smart",
      "style": { "color": "white", "bgcolor": "#2D4F2D", "prefix": " \uf07b " }
    },
    {
      "expr": "pwd.name",
      "style": { "color": "white", "bgcolor": "#2D4F2D", "bold": true, "suffix": " " }
    },
    {
      "value": "\ue0b0",
      "style": { "color": "#2D4F2D", "bgcolor": "#1C3A1C" }
    },
    {
      "expr": "git.branch",
      "style": { "color": "#8FBC8F", "bgcolor": "#1C3A1C", "bold": true, "prefix": " \ue0a0 " }
    },
    {
      "expr": "git.insertions",
      "when": "value > 0",
      "style": { "color": "#50FA7B", "bgcolor": "#1C3A1C", "prefix": " +" }
    },
    {
      "expr": "git.deletions",
      "when": "value > 0",
      "style": { "color": "#FF6B6B", "bgcolor": "#1C3A1C", "prefix": " -", "suffix": " " }
    },
    {
      "value": "\ue0b0",
      "style": { "color": "#1C3A1C", "bgcolor": "#1A2E1A" }
    },
    {
      "expr": "context.tokens",
      "style": { "color": "#A8D5A8", "bgcolor": "#1A2E1A", "bold": true, "prefix": " \uf0e4 " }
    },
    {
      "expr": "context.size",
      "style": { "color": "#A8D5A8", "bgcolor": "#1A2E1A", "prefix": "/" }
    },
    {
      "expr": "context.percent.used",
      "style": { "color": "#A8D5A8", "bgcolor": "#1A2E1A", "prefix": " (", "suffix": ") " }
    },
    {
      "value": "\ue0b0",
      "style": { "color": "#1A2E1A", "bgcolor": "#142814" }
    },
    {
      "expr": "cost.usd",
      "style": { "color": "#6BBF6B", "bgcolor": "#142814", "bold": true, "prefix": " " }
    },
    {
      "expr": "session.duration.total",
      "style": { "color": "#6BBF6B", "bgcolor": "#142814", "prefix": " \uf017 ", "suffix": " " }
    },
    {
      "value": "\ue0b0",
      "style": { "color": "#142814" }
    }
  ]
}
